# Iframe HTML proxy (see README §4).
# `npm run dev` starts the Node proxy on :8787 and defaults to same-origin
# `/__iframe-proxy` (set in vite.config) — you normally leave this unset in dev.
# Production: set to your public proxy origin, e.g. https://proxy.example.com
# VITE_IFRAME_PROXY_BASE=

# Screenshot provider for export (see src/lib/screenshot.ts)
# VITE_SCREENSHOT_PROVIDER=microlink
# VITE_SCREENSHOT_API_KEY=
# VITE_SCREENSHOT_CUSTOM_URL=
