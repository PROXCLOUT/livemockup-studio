{
  "name": "livemockup-studio",
  "private": true,
  "version": "1.0.0",
  "description": "Perspective-correct mockup generator with live URL previews",
  "type": "module",
  "main": "electron/main.cjs",
  "author": "LiveMockup Studio",
  "scripts": {
    "dev": "concurrently -k -n proxy,vite -c cyan,magenta \"npm run proxy\" \"wait-on http://127.0.0.1:8787/health && vite --port=3000 --host=0.0.0.0\"",
    "dev:vite": "vite --port=3000 --host=0.0.0.0",
    "proxy": "node proxy-server/iframe-proxy.mjs",
    "build": "vite build",
    "build:electron": "VITE_IFRAME_PROXY_BASE=http://127.0.0.1:8787 npm run build && electron-builder --mac",
    "electron": "electron .",
    "electron:dev": "concurrently -k -n app,electron -c cyan,magenta \"npm run dev\" \"wait-on http://127.0.0.1:3000 && ELECTRON_START_URL=http://127.0.0.1:3000 electron .\"",
    "preview": "vite preview",
    "clean": "rm -rf dist release",
    "lint": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "clsx": "^2.1.1",
    "fflate": "^0.8.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.14.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitest/coverage-v8": "^3.2.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "electron": "^34.2.0",
    "electron-builder": "^25.1.8",
    "jsdom": "^25.0.1",
    "playwright": "^1.50.1",
    "tailwindcss": "^4.1.14",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vitest": "^3.2.4",
    "wait-on": "^9.0.10"
  },
  "build": {
    "appId": "com.livemockup.studio",
    "productName": "LiveMockup Studio",
    "npmRebuild": false,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/main.cjs",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "proxy-server",
        "to": "proxy-server",
        "filter": [
          "**/*"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.graphics-design",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
